{
  "name": "stemit-cli",
  "version": "1.0.1",
  "description": "CLI tool to split audio into stems (vocals/drums/bass/other), analyze BPM & key, and mute/solo tracks",
  "type": "module",
  "bin": {
    "stemit": "bin/stemit.js",
    "stemit-cli": "bin/stemit.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "audio",
    "stem",
    "demucs",
    "music",
    "bpm",
    "key",
    "vocals",
    "split",
    "remix",
    "cli"
  ],
  "author": "saravanaraja25",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saravanaraja25/stemit-cli.git"
  },
  "homepage": "https://github.com/saravanaraja25/stemit-cli#readme",
  "bugs": {
    "url": "https://github.com/saravanaraja25/stemit-cli/issues"
  },
  "scripts": {
    "start": "node bin/stemit.js"
  },
  "dependencies": {
    "audio-decode": "^2.1.4",
    "debug": "^4.3.7",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "essentia.js": "^0.1.3",
    "figlet": "^1.7.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.1",
    "which": "^4.0.0",
    "youtube-dl-exec": "^3.0.12"
  }
}
